# LLM Configuration
# 选择一个 LLM 提供商并配置其 API key

# OpenAI
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，默认值。支持自定义endpoint（如Azure、本地代理）

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可选，默认值。支持自定义endpoint

# Aliyun Qwen (示例：中文LLM)
# QWEN_API_KEY=your_qwen_api_key_here
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1  # 可选，默认值

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/beta  # 可选，默认值。支持自定义endpoint

# 系统选择哪个 LLM（优先级：环境变量 > 默认openai）
# NOVEL_LLM_PROVIDER=openai

# 常见自定义 base_url 场景:
# 1. Azure OpenAI:
#    OPENAI_BASE_URL=https://<resource-name>.openai.azure.com/
#    OPENAI_API_KEY=<your-azure-api-key>

# 2. 本地 LLM 服务（如 LocalAI, Ollama):
#    OPENAI_BASE_URL=http://localhost:8000/v1
#    OPENAI_MODEL=local-model-name

# 3. 国内代理:
#    OPENAI_BASE_URL=https://api.chatanywhere.com.cn/v1
#    OPENAI_API_KEY=<proxy-key>

---

# Data Directory
DATA_DIR=./data
MEMORIES_DIR=./data/memories
CHROMA_DB_DIR=./data/chroma_db

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/bge-small-zh-v1.5

# System Settings
LOG_LEVEL=INFO
DEBUG=False
